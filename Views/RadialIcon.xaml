<UserControl x:Class="DesktopPanel.Views.RadialIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             RenderTransformOrigin="0.5,0.5"
             Cursor="Hand">
    <UserControl.RenderTransform>
        <ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1"/>
    </UserControl.RenderTransform>

    <Grid>
        <Border Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CornerRadius="12"
                Background="#22FFFFFF"
                Padding="8">
            <Border.Effect>
                <DropShadowEffect x:Name="Glow" Color="{Binding GlowColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  BlurRadius="0" ShadowDepth="0" Opacity="0.9"/>
            </Border.Effect>
            <Image Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   RenderOptions.EdgeMode="Aliased"
                   Source="{Binding IconImage, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </Border>
    </Grid>
</UserControl>
