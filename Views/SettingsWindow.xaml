<Window x:Class="DesktopPanel.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopPanel 设置"
        Width="560" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Icon="pack://application:,,,/Assets/app.ico"
        Background="#FF2B2B2B">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFEEEEEE"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFEEEEEE"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="应用列表（拖拽 exe / 快捷方式到下方区域添加）"
                   FontWeight="Bold" Margin="0,0,0,8"/>

        <Border Grid.Row="1" BorderBrush="#FF555555" BorderThickness="1" CornerRadius="4"
                AllowDrop="True" Drop="OnDropFiles" DragOver="OnDragOver" Background="#FF333333">
            <ListBox x:Name="AppList" Background="Transparent" BorderThickness="0"
                     Foreground="#FFEEEEEE" SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Path}" FontSize="11" Foreground="#FFAAAAAA"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="↑" Width="28" Margin="2,0"
                                    Click="OnMoveUp" Tag="{Binding}"/>
                            <Button Grid.Column="2" Content="↓" Width="28" Margin="2,0"
                                    Click="OnMoveDown" Tag="{Binding}"/>
                            <Button Grid.Column="3" Content="✕" Width="28" Margin="2,0"
                                    Click="OnRemove" Tag="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="2" Background="#FF333333" CornerRadius="4" Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="面板透明度" Margin="0,4,8,4"/>
                <Slider Grid.Row="0" Grid.Column="1" x:Name="OpacitySlider" Minimum="0.2" Maximum="1.0"
                        VerticalAlignment="Center" Margin="0,4" ValueChanged="OnSettingChanged"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="图标大小" Margin="12,4,8,4"/>
                <Slider Grid.Row="0" Grid.Column="3" x:Name="IconSizeSlider" Minimum="40" Maximum="96"
                        VerticalAlignment="Center" Margin="0,4" ValueChanged="OnSettingChanged"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="面板颜色" Margin="0,4,8,4"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="PanelColorBox" Margin="0,4"
                         LostFocus="OnSettingChanged"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="主题色" Margin="12,4,8,4"/>
                <TextBox Grid.Row="1" Grid.Column="3" x:Name="AccentColorBox" Margin="0,4"
                         LostFocus="OnSettingChanged"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="字体颜色" Margin="0,4,8,4"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="FontColorBox" Margin="0,4"
                         LostFocus="OnSettingChanged"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="呼出按键" Margin="12,4,8,4"/>
                <ComboBox Grid.Row="2" Grid.Column="3" x:Name="TriggerKeyCombo" Margin="0,4"
                          SelectionChanged="OnTriggerKeyChanged"/>

                <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" x:Name="StartupCheck"
                          Content="开机自动启动" Foreground="#FFEEEEEE" Margin="0,10,0,0"
                          Checked="OnStartupChanged" Unchecked="OnStartupChanged"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="HintText" Text="提示：长按呼出键在屏幕中心呼出圆盘" Foreground="#FFAAAAAA"
                       VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button Content="关闭" Width="90" Height="30" Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>
